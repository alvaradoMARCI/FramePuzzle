<?xml version="1.0" encoding="utf-8"?>
<!--
    FramePuzzle Adaptive Icon Foreground
    ─────────────────────────────────────────────────────────────────────────
    Concepto: marco minimalista con pieza de puzzle dorada.
    - Marco: representa recuerdos y fotografías.
    - Pieza de puzzle: representa interacción y experiencia.
    - Dorado: progreso, valor y logros (única saturación fuerte).
    - Fondo azul oscuro casi negro (#0B1220) → sensación premium.

    Diseño vectorial: se renderiza a cualquier resolución sin pixelado.
    Viewport 108x108 (adaptive icon), contenido central ~64x64.
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Marco exterior: contorno fino dorado -->
    <path
        android:strokeColor="#FFE8B86C"
        android:strokeWidth="2.5"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000"
        android:pathData="M32,28 L76,28 C78.2,28 80,29.8 80,32 L80,76 C80,78.2 78.2,80 76,80 L32,80 C29.8,80 28,78.2 28,76 L28,32 C28,29.8 29.8,28 32,28 Z" />

    <!-- Marco interior: línea fina blanca translúcida para profundidad -->
    <path
        android:strokeColor="#33FFFFFF"
        android:strokeWidth="1"
        android:fillColor="#00000000"
        android:pathData="M36,32 L72,32 L72,76 L36,76 Z" />

    <!-- Pieza de puzzle central dorada con tab (saliente) arriba y blank (entrante) derecha -->
    <path
        android:fillColor="#FFE8B86C"
        android:pathData="
            M48,44
            L54,44
            C54,42 56,40 58,40
            C60,40 62,42 62,44
            L66,44
            C67.1,44 68,44.9 68,46
            L68,50
            C70,50 72,52 72,54
            C72,56 70,58 68,58
            L68,62
            C68,63.1 67.1,64 66,64
            L62,64
            C62,66 60,68 58,68
            C56,68 54,66 54,64
            L48,64
            C46.9,64 46,63.1 46,62
            L46,46
            C46,44.9 46.9,44 48,44 Z" />

    <!-- Brillo dorado: lighten la esquina superior-izquierda de la pieza -->
    <path
        android:fillColor="#FFF5CE8A"
        android:pathData="M48,46 L52,46 L52,52 L48,52 Z" />

    <!-- Línea fina dorada oscura: detalle minimalista abajo -->
    <path
        android:strokeColor="#FFB8893E"
        android:strokeWidth="1.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M40,76 L68,76" />
</vector>
