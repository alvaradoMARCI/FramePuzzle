<?xml version="1.0" encoding="utf-8"?>
<!--
    FramePuzzle Adaptive Icon Foreground
    ─────────────────────────────────────────────────────────────────────────
    CONCEPTO: Marco minimalista con 4 piezas de puzzle ensamblándose,
    una de ellas dorada para representar logro y la pieza "especial"
    que falta por completar (concepto de "arma tus recuerdos").

    Características:
    - Marco fino con esquinas redondeadas.
    - 4 piezas en disposición 2×2 (forma real de puzzle, no cuadrados).
    - Pieza superior-izquierda dorada (acento, logro, valor).
    - Otras 3 piezas en azul moderno (color primario del Design System).
    - Sombra sutil debajo para profundidad.
    - Todo vectorial: sin pixelado a ninguna resolución.

    Viewport: 108×108 (adaptive icon).
    Contenido seguro: centrado en 36-72 (centro 36×36).
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- Sombra del marco (offset 2px abajo) -->
    <path
        android:fillColor="#33000000"
        android:pathData="M30,32 L78,32 C80.2,32 82,33.8 82,36 L82,82 C82,84.2 80.2,86 78,86 L30,86 C27.8,86 26,84.2 26,82 L26,36 C26,33.8 27.8,32 30,32 Z" />

    <!-- Marco: contorno fino blanco translúcido -->
    <path
        android:strokeColor="#40FFFFFF"
        android:strokeWidth="1"
        android:fillColor="#00000000"
        android:pathData="M30,30 L78,30 C80.2,30 82,31.8 82,34 L82,80 C82,82.2 80.2,84 78,84 L30,84 C27.8,84 26,82.2 26,80 L26,34 C26,31.8 27.8,30 30,30 Z" />

    <!--
        Piezas de puzzle 2×2:
          [PIEZA-1: DORADA] [PIEZA-2: AZUL]
          [PIEZA-3: AZUL]   [PIEZA-4: AZUL]
        Cada pieza tiene tabs/blanks que encajan con sus vecinas.
        Tab superior y derecho en PIEZA-1 (salientes hacia afuera del marco).
    -->

    <!-- PIEZA 1: superior izquierda, DORADA, con tab superior y tab izquierdo -->
    <path
        android:fillColor="#FFD4A24E"
        android:pathData="
            M40,40
            L52,40
            C52,37 55,35 58,35
            C61,35 64,37 64,40
            L72,40
            L72,52
            C75,52 77,55 77,58
            C77,61 75,64 72,64
            L72,72
            L40,72
            Z" />

    <!-- Brillo dorado en esquina superior-izquierda de PIEZA 1 -->
    <path
        android:fillColor="#FFE8C078"
        android:pathData="M42,42 L52,42 L52,48 L42,48 Z" />

    <!-- PIEZA 2: superior derecha, AZUL MODERNO, con blank izquierdo (recibe tab de PIEZA 1) -->
    <path
        android:fillColor="#FF3B82F6"
        android:pathData="
            M72,40
            L80,40
            L80,72
            L72,72
            L72,64
            C75,64 77,61 77,58
            C77,55 75,52 72,52
            Z" />

    <!-- PIEZA 3: inferior izquierda, AZUL, con blank superior -->
    <path
        android:fillColor="#FF3B82F6"
        android:pathData="
            M40,72
            L72,72
            L72,80
            L40,80
            Z" />

    <!-- PIEZA 4: inferior derecha, AZUL más oscuro para profundidad -->
    <path
        android:fillColor="#FF1E40AF"
        android:pathData="
            M72,72
            L80,72
            L80,80
            L72,80
            Z" />

    <!-- Línea de separación sutil entre piezas (borde blanco translúcido) -->
    <path
        android:strokeColor="#20FFFFFF"
        android:strokeWidth="0.8"
        android:fillColor="#00000000"
        android:pathData="M72,40 L72,80" />
    <path
        android:strokeColor="#20FFFFFF"
        android:strokeWidth="0.8"
        android:fillColor="#00000000"
        android:pathData="M40,72 L80,72" />

    <!-- Pequeño highlight dorado: punto de luz en PIEZA 1 -->
    <path
        android:fillColor="#FFF5E1B8"
        android:pathData="M44,44 L48,44 L48,46 L44,46 Z" />

</vector>
